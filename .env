# Database Credentials for SISTARA Jewels
# Configure these for Vercel/Production deployment.
# For local WAMP/XAMPP development, you can leave these defaults.

# ----------------------------------------------------
# Main Database Credentials (Used for User Accounts)
# ----------------------------------------------------
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=user

# ----------------------------------------------------
# Optional Override Database Names
# (Defaults to DB_NAME if left blank, but recommended
# to keep separate as configured here)
# ----------------------------------------------------
CART_DB_NAME=addtocart
ORDERS_DB_NAME=orders
CONTACT_DB_NAME=user1
