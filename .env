# Database Credentials for SISTARA Jewels
# Configure these for Vercel/Production deployment.
# For local WAMP/XAMPP development, you can leave these defaults.

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=user

# Optional override database names (will default to DB_NAME if left blank)
CART_DB_NAME=addtocart
ORDERS_DB_NAME=orders
CONTACT_DB_NAME=user1
