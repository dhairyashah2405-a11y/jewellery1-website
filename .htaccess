RewriteEngine On

# Route static images to the frontend folder
RewriteRule ^images/(.*)$ frontend/images/$1 [L]
RewriteRule ^bracelet\ images/(.*)$ frontend/bracelet\ images/$1 [L]
RewriteRule ^earring\ images/(.*)$ frontend/earring\ images/$1 [L]
RewriteRule ^necklace\ images/(.*)$ frontend/necklace\ images/$1 [L]
RewriteRule ^ring\ images/(.*)$ frontend/ring\ images/$1 [L]
RewriteRule ^uploads/(.*)$ frontend/uploads/$1 [L]

# Route backend process scripts to the backend folder
RewriteRule ^insert_cart\.php$ backend/insert_cart.php [L]
RewriteRule ^remove_cart\.php$ backend/remove_cart.php [L]
RewriteRule ^sync_cart\.php$ backend/sync_cart.php [L]
RewriteRule ^update_cart_quantity\.php$ backend/update_cart_quantity.php [L]
RewriteRule ^register_process\.php$ backend/register_process.php [L]
RewriteRule ^logout\.php$ backend/logout.php [L]
RewriteRule ^p1\.php$ backend/p1.php [L]
RewriteRule ^p3\.php$ backend/p3.php [L]
RewriteRule ^p4\.php$ backend/p4.php [L]
RewriteRule ^p5\.php$ backend/p5.php [L]

# Route clean URLs and original page names to the frontend folder
RewriteRule ^about$ frontend/about.php [L]
RewriteRule ^about\.php$ frontend/about.php [L]
RewriteRule ^add-to-cart$ frontend/add\ to\ cart.php [L]
RewriteRule ^add\ to\ cart\.php$ frontend/add\ to\ cart.php [L]
RewriteRule ^admin$ frontend/admin.php [L]
RewriteRule ^admin\.php$ frontend/admin.php [L]
RewriteRule ^blog$ frontend/blog.php [L]
RewriteRule ^blog\.php$ frontend/blog.php [L]
RewriteRule ^blog1$ frontend/blog1.php [L]
RewriteRule ^blog1\.php$ frontend/blog1.php [L]
RewriteRule ^blog2$ frontend/blog2.php [L]
RewriteRule ^blog2\.php$ frontend/blog2.php [L]
RewriteRule ^blog3$ frontend/blog3.php [L]
RewriteRule ^blog3\.php$ frontend/blog3.php [L]
RewriteRule ^checkout$ frontend/checkout.php [L]
RewriteRule ^checkout\.php$ frontend/checkout.php [L]
RewriteRule ^contact$ frontend/contact.php [L]
RewriteRule ^contact\.php$ frontend/contact.php [L]
RewriteRule ^display_order$ frontend/display_order.php [L]
RewriteRule ^display_order\.php$ frontend/display_order.php [L]
RewriteRule ^featured$ frontend/featured.php [L]
RewriteRule ^featured\.php$ frontend/featured.php [L]
RewriteRule ^home$ frontend/home.php [L]
RewriteRule ^home\.php$ frontend/home.php [L]
RewriteRule ^login$ frontend/login.php [L]
RewriteRule ^login\.php$ frontend/login.php [L]
RewriteRule ^product$ frontend/product.php [L]
RewriteRule ^product\.php$ frontend/product.php [L]
RewriteRule ^product-detail$ frontend/product\ detail.php [L]
RewriteRule ^product\ detail\.php$ frontend/product\ detail.php [L]
RewriteRule ^profile$ frontend/profile.php [L]
RewriteRule ^profile\.php$ frontend/profile.php [L]
RewriteRule ^register$ frontend/register.php [L]
RewriteRule ^register\.php$ frontend/register.php [L]
RewriteRule ^shop$ frontend/shop.php [L]
RewriteRule ^shop\.php$ frontend/shop.php [L]
RewriteRule ^view_orders$ frontend/view_orders..php [L]
RewriteRule ^view_orders\.\.php$ frontend/view_orders..php [L]
RewriteRule ^wishlist$ frontend/wishlist.php [L]
RewriteRule ^wishlist\.php$ frontend/wishlist.php [L]

# Route root to home.php
RewriteRule ^$ frontend/home.php [L]
